# Copy to .env and fill in your values.

# ============================================================
# LLM Provider Selection (EXPLICIT)
# ============================================================
# Options: "openai" (default), "anthropic", "ollama", "vllm", "localai", "auto"
# - "openai": Use OpenAI-compatible API (vLLM, Ollama, etc.)
# - "anthropic": Use Anthropic Claude API
# - "auto": Auto-detect based on API keys (fallback)
LLM_PROVIDER=openai

# ============================================================
# OpenAI-Compatible API (vLLM, Ollama, LocalAI, etc.)
# ============================================================
# URL of the OpenAI-compatible inference server
LLM_BASE_URL=http://127.0.0.1:8002/v1

# Default model name passed to the server
DEFAULT_MODEL=gemma-4-4B-abliterated

# API key (use "no-key" for local servers that don't require one)
LLM_API_KEY=no-key

# ============================================================
# Anthropic Claude API
# ============================================================
# Required when LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# DEFAULT_MODEL=claude-3-5-sonnet-20241022

# ============================================================
# Other
# ============================================================
# Sandbox dir - where the server will store temporary files
SANDBOX_DIR=./sandbox